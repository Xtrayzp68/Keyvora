<Window x:Class="Keyvora.Desktop.UI.Views.ActionEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:viewmodels="clr-namespace:Keyvora.Desktop.UI.ViewModels"
        Title="Edit Action"
        Width="500"
        Height="540"
        MinWidth="500"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select an Action" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" x:Name="ActionListBox"
                 ItemsSource="{Binding AvailableActions}"
                 SelectedItem="{Binding SelectedAction}"
                 SelectionChanged="OnActionSelectionChanged"
                 BorderBrush="{StaticResource BorderBrush}"
                 Background="{StaticResource SurfaceBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="viewmodels:ActionItem">
                    <Border Background="Transparent" Padding="8,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Row="1" Text="{Binding Description}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Config Panel -->
        <Border Grid.Row="2" x:Name="ConfigPanel" Visibility="Collapsed"
                Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom Label -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Custom label (optional):" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ConfigLabel, UpdateSourceTrigger=PropertyChanged}" Padding="6,4"/>
                </StackPanel>

                <Grid Grid.Row="1">
                <!-- Open File -->
                <StackPanel x:Name="PanelOpenFile" Visibility="Collapsed">
                    <TextBlock Text="File to open:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConfigFilePath}" IsReadOnly="True"
                                 Background="{StaticResource SurfaceLightBrush}" Padding="6,4"/>
                        <Button Grid.Column="1" Content="Browse..." Style="{StaticResource SecondaryButton}"
                                Padding="8,4" Margin="4,0,0,0" Click="OnBrowseFile"/>
                    </Grid>
                </StackPanel>

                <!-- Keyboard Shortcut -->
                <StackPanel x:Name="PanelKeyboard" Visibility="Collapsed">
                    <TextBlock Text="Shortcut keys:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Examples: Ctrl+C, Alt+Tab, Ctrl+Shift+A, Win+D"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ConfigKeyboardKeys, UpdateSourceTrigger=PropertyChanged}" Padding="6,4"/>
                </StackPanel>

                <!-- Type Text -->
                <StackPanel x:Name="PanelText" Visibility="Collapsed">
                    <TextBlock Text="Text to type:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ConfigText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" TextWrapping="Wrap" MinLines="2"/>
                </StackPanel>

                <!-- Spotify -->
                <StackPanel x:Name="PanelSpotify" Visibility="Collapsed">
                    <TextBlock Text="Command:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding SpotifyCommands}"
                              SelectedItem="{Binding ConfigSpotifyCommand}"
                              Background="{StaticResource SurfaceLightBrush}" Padding="6,4"/>
                </StackPanel>

                <!-- Macro -->
                <StackPanel x:Name="PanelMacro" Visibility="Collapsed">
                    <TextBlock Text="Macro actions are configured by assigning multiple actions to buttons."
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Play Sound -->
                <StackPanel x:Name="PanelPlaySound" Visibility="Collapsed">
                    <TextBlock Text="Audio file (MP3, WAV, etc.):" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConfigSoundFilePath}" IsReadOnly="True"
                                 Background="{StaticResource SurfaceLightBrush}" Padding="6,4"/>
                        <Button Grid.Column="1" Content="Browse..." Style="{StaticResource SecondaryButton}"
                                Padding="8,4" Margin="4,0,0,0" Click="OnBrowseSoundFile"/>
                    </Grid>
                    <TextBlock Text="Output device (optional):" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <ComboBox ItemsSource="{Binding AudioDevices}"
                              SelectedValue="{Binding ConfigSoundDeviceId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Background="{StaticResource SurfaceLightBrush}" Padding="6,4"/>
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,6,0,0">
                        <Run Text="Tip:" FontWeight="SemiBold"/>
                        <Run Text="To route sound through your microphone, select a Wave Link device (SFX, Stream, etc.) or install VB-Cable (vb-audio.com). Use Wave Link routing to send SFX to both Monitor and MicrophoneFX."/>
                    </TextBlock>
                </StackPanel>

                <!-- Discord -->
                <StackPanel x:Name="PanelDiscord" Visibility="Collapsed">
                    <TextBlock Text="Command:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DiscordCommands}"
                              SelectedItem="{Binding ConfigDiscordCommand}"
                              Background="{StaticResource SurfaceLightBrush}" Padding="6,4"/>
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,6,0,0">
                        Connect Discord in the Plugins panel (🔌 button in title bar).</TextBlock>
                </StackPanel>

                <!-- Streamlabs / OBS -->
                <StackPanel x:Name="PanelStreamlabs" Visibility="Collapsed">
                    <TextBlock Text="Command:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="StreamlabsCommandCombo"
                              ItemsSource="{Binding StreamlabsCommands}"
                              SelectedItem="{Binding ConfigStreamlabsCommand, UpdateSourceTrigger=PropertyChanged}"
                              Background="{StaticResource SurfaceLightBrush}" Padding="6,4"
                              SelectionChanged="OnStreamlabsCommandChanged"/>

                    <TextBlock Text="Scene:" FontWeight="SemiBold" Margin="0,6,0,4"
                               x:Name="StreamlabsSceneLabel" Visibility="Collapsed"/>
                    <ComboBox x:Name="StreamlabsSceneCombo"
                              ItemsSource="{Binding StreamlabsScenes}"
                              SelectedItem="{Binding ConfigStreamlabsSceneName, UpdateSourceTrigger=PropertyChanged}"
                              Background="{StaticResource SurfaceLightBrush}" Padding="6,4"
                              Visibility="Collapsed"
                              SelectionChanged="OnStreamlabsSceneChanged"/>

                    <TextBlock Text="Source:" FontWeight="SemiBold" Margin="0,6,0,4"
                               x:Name="StreamlabsSourceLabel" Visibility="Collapsed"/>
                    <ComboBox x:Name="StreamlabsSourceCombo"
                              ItemsSource="{Binding StreamlabsSources}"
                              SelectedItem="{Binding ConfigStreamlabsSourceName, UpdateSourceTrigger=PropertyChanged}"
                              Background="{StaticResource SurfaceLightBrush}" Padding="6,4"
                              Visibility="Collapsed"/>

                    <TextBlock x:Name="StreamlabsConnectionHint" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="10" Margin="0,8,0,0" TextWrapping="Wrap"
                               Text="Configure Streamlabs connection in the Plugins panel (🔌 button in title bar)."/>
                </StackPanel>
            </Grid>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Assign" Style="{StaticResource PrimaryButton}" IsDefault="True" Click="OnAssignClick"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
