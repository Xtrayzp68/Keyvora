<Window x:Class="Keyvora.Desktop.UI.Views.DisplayEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:Keyvora.Desktop.UI.Converters"
        Title="Edit Display"
        Width="380"
        Height="520"
        MinWidth="380"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <converters:ResourceKeyToImageConverter x:Key="ResourceKeyToImageConverter"/>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Background="{StaticResource BackgroundBrush}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Edit Button Display" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Icon / Image -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Icon:" FontWeight="SemiBold" Margin="0,0,0,4"/>

                        <!-- Preview -->
                        <Border Width="60" Height="60"
                                CornerRadius="6"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Background="{StaticResource SurfaceBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,8">
                            <Grid>
                                <Image Source="{Binding PreviewSource}"
                                       Width="44" Height="44"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImageSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="?"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#606060">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImageSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Built-in icons grid -->
                        <TextBlock Text="Built-in:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="BuiltInIconsControl"
                                      ItemsSource="{Binding BuiltInIcons}"
                                      MaxHeight="96">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel MaxWidth="340"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="36" Height="36" CornerRadius="4"
                                            Margin="2" Cursor="Hand"
                                            BorderBrush="#555555" BorderThickness="1"
                                            Background="{StaticResource SurfaceBrush}"
                                            MouseLeftButtonDown="OnBuiltInIconClick"
                                            Tag="{Binding ResourceKey}"
                                            ToolTip="{Binding Name}">
                                        <Image Width="24" Height="24"
                                               Stretch="Uniform"
                                               Source="{Binding ResourceKey, Converter={StaticResource ResourceKeyToImageConverter}}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Custom image -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Browse image..."
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OnBrowseImageClick"
                                    Margin="0,0,8,0"/>
                            <Button Content="Clear"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OnClearIconClick"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CustomImagePath}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="320"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Crop button (only visible when image selected) -->
                    <Button x:Name="CropButton"
                            Content="✧ Recadrer l'image"
                            Height="32" FontSize="12" Padding="16,0"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12"
                            Cursor="Hand"
                            Click="OnCropClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    BorderThickness="0"
                                                    Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImageSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Label / Title -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Title:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6"
                                 Background="{StaticResource SurfaceBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"/>
                    </StackPanel>

                    <!-- Background Color -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Background Color:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="32" Height="32"
                                    CornerRadius="4"
                                    Margin="0,0,8,0"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6"
                                     Background="{StaticResource SurfaceBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Preset Colors -->
                    <TextBlock Text="Presets:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="PresetColorsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel MaxWidth="340"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="28" Height="28" CornerRadius="4"
                                        Margin="2" Cursor="Hand"
                                        BorderBrush="#555555" BorderThickness="1"
                                        MouseLeftButtonDown="OnPresetColorClick"
                                        Tag="{Binding}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding}"/>
                                    </Border.Background>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="OK" Style="{StaticResource PrimaryButton}" IsDefault="True" Click="OnOkClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
