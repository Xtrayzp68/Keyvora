<Window x:Class="Keyvora.Desktop.UI.Views.CropDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:Keyvora.Desktop.UI.Converters"
        Title="Recadrer l'image"
        Width="420"
        Height="520"
        MinWidth="420"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        UseLayoutRounding="True">
    <Window.Resources>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Background="{StaticResource BackgroundBrush}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Crop &amp; Zoom" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <!-- Preview: shows exactly how the image will appear on the tile -->
            <Border Grid.Row="1"
                    Width="240" Height="240"
                    CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Background="#1A1A1A"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,0,0,12">
                <Border.Clip>
                    <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,240,240"/>
                </Border.Clip>
                <Grid>
                    <Image Source="{Binding PreviewSource}"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderTransform="{Binding ImageTransform}"
                           RenderTransformOrigin="0.5,0.5"/>
                    <Border VerticalAlignment="Bottom" Height="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#80000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Border>

            <!-- Controls -->
            <StackPanel Grid.Row="2">
                <!-- Zoom -->
                <StackPanel Margin="0,0,0,10">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Zoom:" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ImageScale, StringFormat={}{0:F2}x}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="−" Width="28" Height="28"
                                FontSize="16" FontWeight="Bold"
                                Style="{StaticResource SecondaryButton}" Padding="0"
                                Click="OnZoomOutClick"/>
                        <Slider Grid.Column="1" Margin="8,0"
                                Value="{Binding ImageScale, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0.5" Maximum="5.0" SmallChange="0.05" LargeChange="0.5"
                                TickFrequency="0.5"/>
                        <Button Grid.Column="2" Content="+" Width="28" Height="28"
                                FontSize="16" FontWeight="Bold"
                                Style="{StaticResource SecondaryButton}" Padding="0"
                                Click="OnZoomInClick"/>
                    </Grid>
                </StackPanel>

                <!-- Horizontal offset -->
                <StackPanel Margin="0,0,0,8">
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Horizontal:" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ImageOffsetX, StringFormat={}{F0}px}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </Grid>
                    <Slider Value="{Binding ImageOffsetX, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="-100" Maximum="100" SmallChange="1" LargeChange="10"/>
                </StackPanel>

                <!-- Vertical offset -->
                <StackPanel Margin="0,0,0,8">
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vertical:" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ImageOffsetY, StringFormat={}{F0}px}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </Grid>
                    <Slider Value="{Binding ImageOffsetY, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="-100" Maximum="100" SmallChange="1" LargeChange="10"/>
                </StackPanel>

                <!-- Reset + Buttons -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Reset"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" FontSize="11" Padding="12,0"
                            Click="OnResetClick"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" IsCancel="True" Width="80"/>
                        <Button Content="OK" Style="{StaticResource PrimaryButton}"
                                IsDefault="True" Click="OnOkClick" Width="80"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
