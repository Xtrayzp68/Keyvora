<Window x:Class="Keyvora.Desktop.UI.Views.PluginsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Plugins"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Plugins" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,16">
                <!-- ======== Spotify Section ======== -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Spotify" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" x:Name="SpotifyStatusDot"
                                         Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                         Fill="#F44336"/>
                                <TextBlock Grid.Column="1" x:Name="SpotifyStatusText"
                                           Text="{Binding SpotifyStatus}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button x:Name="SpotifyAuthorizeBtn"
                                            Content="Authorize"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,3" FontSize="11"
                                            Command="{Binding AuthorizeSpotifyCommand}"
                                            Margin="0,0,4,0"/>
                                    <Button x:Name="SpotifyDisconnectBtn"
                                            Content="Disconnect"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,3" FontSize="11"
                                            Command="{Binding DisconnectSpotifyCommand}"
                                            IsEnabled="{Binding IsSpotifyAuthorized}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Authorize Spotify to control playback from your Keyvora. Configure ClientId/Secret in appsettings.json."
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ======== Streamlabs Section ======== -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Streamlabs Desktop" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Host:" FontWeight="SemiBold" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1" Text="{Binding StreamlabsHost, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="4,2" FontSize="11" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="2" Text="{Binding StreamlabsPort, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60" Padding="4,2" FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="3" Text="Port" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="API Token:" FontWeight="SemiBold" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <PasswordBox Grid.Column="1" x:Name="StreamlabsPasswordBox"
                                         Padding="4,2" FontSize="11"
                                         PasswordChanged="OnStreamlabsPasswordChanged"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" x:Name="StreamlabsStatusDot"
                                     Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="#F44336"/>
                            <TextBlock Grid.Column="1" x:Name="StreamlabsStatusText"
                                       Text="{Binding StreamlabsConnectionStatus}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" x:Name="StreamlabsConnectBtn"
                                    Content="Connect"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="8,3" FontSize="11"
                                    Click="OnStreamlabsConnectClick"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ======== Discord Section ======== -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Discord Voice" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Client ID:" FontWeight="SemiBold" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1" Text="{Binding DiscordClientId, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="4,2" FontSize="11"/>
                        </Grid>

                        <TextBlock Text="Create a Discord Application at discord.com/developers to get your Client ID."
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" x:Name="DiscordStatusDot"
                                     Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="#F44336"/>
                            <TextBlock Grid.Column="1" Text="{Binding DiscordStatus}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" x:Name="DiscordConnectBtn"
                                    Content="Connect"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="8,3" FontSize="11"
                                    Click="OnDiscordConnectClick"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Style="{StaticResource PrimaryButton}" IsDefault="True"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
