<UserControl x:Class="Keyvora.Desktop.UI.Controls.KeyvoraButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:Keyvora.Desktop.UI.ViewModels"
             xmlns:converters="clr-namespace:Keyvora.Desktop.UI.Converters"
             Width="120" Height="120">

    <UserControl.Resources>
        <viewmodels:ButtonViewModel x:Key="DesignViewModel"/>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>

    <UserControl.ContextMenu>
        <ContextMenu Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1">
            <MenuItem Header="Clear action" Click="OnClearAction"/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Border x:Name="ButtonBorder"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="8"
            SnapsToDevicePixels="True"
            ToolTip="Double-click to configure">
        <Border.Clip>
            <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,120,120"/>
        </Border.Clip>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="#0078D4"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- Image background (fills entire tile) -->
            <Image Source="{Binding IconSource}"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransform="{Binding ImageTransform}"
                   RenderTransformOrigin="0.5,0.5">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <!-- Dark overlay for label readability over images -->
            <Border VerticalAlignment="Bottom" Height="20">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#A0000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Button number badge -->
                <Border Grid.Row="0"
                        Background="#1A1A1A"
                        CornerRadius="4"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="-2,-2,0,0">
                    <TextBlock Text="{Binding Index}"
                               Foreground="#606060"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Image icon display (when HasImage is true, this is hidden by style;
                     the background Image above handles it. These viewboxes are fallbacks.) -->
                <!-- Text icon (emoji/text, when no image) -->
                <Viewbox Grid.Row="0"
                         Stretch="Uniform"
                         MaxWidth="40"
                         MaxHeight="40"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Viewbox.Style>
                        <Style TargetType="Viewbox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasImage}" Value="False"/>
                                        <Condition Binding="{Binding HasCustomIcon}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Viewbox.Style>
                    <TextBlock Text="{Binding Icon}"
                               FontSize="24"
                               TextAlignment="Center"/>
                </Viewbox>

                <!-- Action icon (text fallback) -->
                <Viewbox Grid.Row="0"
                         Stretch="Uniform"
                         MaxWidth="40"
                         MaxHeight="40"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Viewbox.Style>
                        <Style TargetType="Viewbox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasImage}" Value="False"/>
                                        <Condition Binding="{Binding HasCustomIcon}" Value="False"/>
                                        <Condition Binding="{Binding HasAction}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Viewbox.Style>
                    <TextBlock Text="{Binding ActionDisplayName}"
                               FontSize="11"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Viewbox>

                <!-- Empty state -->
                <Viewbox Grid.Row="0"
                         Stretch="Uniform"
                         MaxWidth="32"
                         MaxHeight="32"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Viewbox.Style>
                        <Style TargetType="Viewbox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasImage}" Value="False"/>
                                        <Condition Binding="{Binding HasCustomIcon}" Value="False"/>
                                        <Condition Binding="{Binding HasAction}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Viewbox.Style>
                    <TextBlock Text="＋" FontSize="24" Foreground="#606060"/>
                </Viewbox>

                <!-- Label -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Label}"
                           Foreground="#E0E0E0"
                           FontSize="10"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4,0,0"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
